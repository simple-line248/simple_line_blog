---
import { Image } from 'astro:assets';
import avatarImg from '../assets/avatar.png';

interface Props {
	title?: string;
}

const { title = "我的博客" } = Astro.props;
const pathname = Astro.url.pathname;
---
<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<!-- 引入 KaTeX 样式文件，用于正确渲染数学公式 -->
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" integrity="sha384-n8MVd4RsEw0928230nTFVn12kReQkWeB108Krt5NhrB5hP16qEoQ/gEocI7JxaRM" crossorigin="anonymous">
	</head>
	<body>
		<div class="layout-wrapper">
			<aside class="sidebar">
				<div class="sidebar-content">
					<div class="site-header">
						<!-- 头像：用了一个非常柔和的方圆角，避免正圆的呆板。使用 Astro Image 优化，首次加载直接生成，不再闪烁 -->
						<Image class="avatar" src={avatarImg} alt="Avatar" width={80} height={80} loading="eager" />
						<h1 class="site-title">SimpleLine's Blog</h1>
						<p class="site-desc">结构、美学与文字的交汇。</p>
					</div>
					
					<nav class="nav-links">
						<a href={import.meta.env.BASE_URL} class={pathname === import.meta.env.BASE_URL ? "active" : ""}>
							<span class="cn">文章</span>
							<span class="en">Writing</span>
						</a>
						<a href={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/projects`} class={pathname.includes("/projects") ? "active" : ""}>
							<span class="cn">项目</span>
							<span class="en">Projects</span>
						</a>
						<a href={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/about`} class={pathname.includes("/about") ? "active" : ""}>
							<span class="cn">履历</span>
							<span class="en">About</span>
						</a>
					</nav>
					
					<!-- 底部信息区：利用 flex-grow 推到底部 -->
					<div class="sidebar-footer">
						<!-- 强调邮箱的展示 -->
						<div class="contact-email">
							<span class="email-label">Get in touch</span>
							<a href="mailto:simpleline248@gmail.com">simpleline248@gmail.com</a>
						</div>
						
						<!-- 社交面板 -->
						<div class="social-links">
							<!-- GitHub -->
							<a href="https://github.com" target="_blank" aria-label="GitHub">
								<svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
							</a>
							<!-- X / Twitter -->
							<a href="https://twitter.com" target="_blank" aria-label="Twitter">
								<svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path></svg>
							</a>
							
							<!-- 暗黑模式切换按钮 -->
							<button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
								<!-- 太阳图标 -->
								<svg class="sun-icon" viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
								<!-- 月亮图标 -->
								<svg class="moon-icon" style="display: none;" viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
							</button>
						</div>
					</div>
				</div>
			</aside>
			<main class="main-content">
				<slot />
			</main>
		</div>

		<!-- 处理暗黑模式的脚本，添加 is:inline 防止 Astro 压缩，且避免白屏闪烁 -->
		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			})();
		
			if (theme === 'light') {
				document.documentElement.classList.remove('dark');
			} else {
				document.documentElement.classList.add('dark');
			}
		
			window.localStorage.setItem('theme', theme);
		
			const handleToggleClick = () => {
				const element = document.documentElement;
				element.classList.toggle("dark");
				
				const isDark = element.classList.contains("dark");
				localStorage.setItem("theme", isDark ? "dark" : "light");
				
				document.querySelector('.sun-icon').style.display = isDark ? 'none' : 'block';
				document.querySelector('.moon-icon').style.display = isDark ? 'block' : 'none';
			}
		
			// 等待 DOM 加载后绑定事件
			document.addEventListener("DOMContentLoaded", () => {
				document.getElementById("theme-toggle").addEventListener("click", handleToggleClick);
				const isDark = document.documentElement.classList.contains("dark");
				document.querySelector('.sun-icon').style.display = isDark ? 'none' : 'block';
				document.querySelector('.moon-icon').style.display = isDark ? 'block' : 'none';
			});
		</script>
	</body>
</html>

<style is:global>
	:root {
		/* 1A: 暖白/米色调 */
		--bg-color: #FDFBF7; 
		/* 稍微降对比度的黑，防止刺眼 */
		--text-color: #2C2C2C; 
		/* 次要文字色彩，做层级区分 */
		--text-muted: #858585; 
		/* 极其微弱的边框辅助结构 */
		--border-color: rgba(0, 0, 0, 0.06); 
		/* 按钮、标签的柔和底色 */
		--element-bg: rgba(0, 0, 0, 0.04);
		--element-hover: rgba(0, 0, 0, 0.08);
	}

	html.dark {
		--bg-color: #121212; 
		--text-color: #E6E6E6; 
		--text-muted: #8E8E8E; 
		--border-color: rgba(255, 255, 255, 0.08); 
		--element-bg: rgba(255, 255, 255, 0.06);
		--element-hover: rgba(255, 255, 255, 0.12);
	}

	* {
		box-sizing: border-box; /* 全局添加此属性防止撑破布局 */
	}

	html, body {
		margin: 0;
		padding: 0;
		width: 100%;
		min-height: 100vh;
		background-color: var(--bg-color);
		color: var(--text-color);
		/* 2A: 现代无衬线体 */
		font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
		line-height: 1.6;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}
	a {
		color: inherit;
		text-decoration: none;
	}

	/* 3B: 侧边栏结构优化：放宽整体限制，让排版更舒展 */
	.layout-wrapper {
		display: flex;
		max-width: 1200px; /* 从 1000px 放大到 1200px，减少拥挤感 */
		margin: 0 auto;
		min-height: 100vh;
	}

	.sidebar {
		width: 260px; /* 侧边栏也稍微加宽一点 */
		padding: 80px 30px; /* 增加上下和左右的内边距，让呼吸感更足 */
		flex-shrink: 0;
	}

	.sidebar-content {
		position: sticky;
		top: 80px; /* 跟随 padding 调整吸顶位置 */
		display: flex;
		flex-direction: column;
		height: calc(100vh - 160px); /* 让侧边栏内容撑满屏幕，方便底部对齐 */
	}

	.site-header {
		flex-shrink: 0;
	}

	.avatar {
		width: 80px; /* 头像稍微放大一点，增加个人标识的重力 */
		height: 80px;
		border-radius: 20px; 
		object-fit: cover;
		margin-bottom: 20px;
		background-color: rgba(0, 0, 0, 0.05);
	}

	.site-title {
		font-size: 1.2rem;
		font-weight: 600;
		margin: 0 0 4px 0;
		letter-spacing: 0.5px;
	}

	.site-desc {
		font-size: 0.85rem;
		color: var(--text-muted);
		margin: 0 0 32px 0;
		line-height: 1.6;
	}

	.nav-links {
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	.nav-links a {
		display: flex;
		align-items: center;
		justify-content: space-between;
		font-size: 0.95rem;
		color: var(--text-muted);
		transition: color 0.2s ease;
		padding: 8px 0; /* 增加上下 padding，防止被挤在一起 */
	}

	.nav-links a .cn {
		font-weight: 500;
	}

	.nav-links a .en {
		font-size: 0.8rem;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		opacity: 0.6;
	}

	.nav-links a:hover,
	.nav-links a.active {
		color: var(--text-color);
		font-weight: 500;
	}

	.sidebar-footer {
		margin-top: auto; /* 自动推到最底部 */
		display: flex;
		flex-direction: column;
		gap: 20px;
	}

	.contact-email {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.email-label {
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 1px;
		color: var(--text-muted);
		opacity: 0.8;
	}

	.contact-email a {
		font-size: 0.95rem;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
		color: var(--text-color);
		transition: opacity 0.2s ease;
	}

	.contact-email a:hover {
		opacity: 0.6;
	}

	.social-links {
		display: flex;
		align-items: center;
		gap: 16px;
		padding-top: 24px;
		border-top: 1px dashed var(--border-color); 
	}

	.social-links a, .theme-toggle {
		color: var(--text-muted);
		transition: color 0.2s ease, transform 0.2s ease;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.theme-toggle {
		background: none;
		border: none;
		cursor: pointer;
		padding: 0;
		margin-left: auto; /* 把主题切换按钮推到最右边 */
	}

	.social-links a:hover, .theme-toggle:hover {
		color: var(--text-color);
		transform: translateY(-2px); /* 轻微互动物理反馈 */
	}

	.main-content {
		flex: 1;
		padding: 80px 40px 80px 80px; /* 增加整体内边距 */
		border-left: 1px solid var(--border-color); 
	}

	/* 响应式：屏幕太小时，自动把侧边栏挪到上面 */
	@media (max-width: 768px) {
		.layout-wrapper {
			flex-direction: column;
		}
		.sidebar {
			width: 100%;
			padding: 40px 20px 20px;
			border-bottom: 1px solid var(--border-color);
			box-sizing: border-box;
		}
		.sidebar-content {
			position: relative;
			top: 0;
		}
		.nav-links {
			flex-direction: row;
			gap: 20px;
			margin-top: 16px;
		}
		.main-content {
			padding: 40px 20px;
			border-left: none;
		}
	}
</style>
